choice
	prompt "Built for static lib or shared lib"
	default libvorbis-sharedlib 
	default libvorbis-staticlib if minidlna-staticlink
	depends PACKAGE_libvorbis
	help
	  This option allows you to select the type while linking.

	config libvorbis-sharedlib
		bool "shared lib"
		depends !minidlna-staticlink

	config libvorbis-staticlib
		bool "static lib"
		depends minidlna-staticlink
endchoice
