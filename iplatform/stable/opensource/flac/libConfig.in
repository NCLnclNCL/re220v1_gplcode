choice
	prompt "Built for static lib or shared lib"
	default libflac-sharedlib 
	default libflac-staticlib if minidlna-staticlink
	depends PACKAGE_libflac
	help
	  This option allows you to select the type while linking.

	config libflac-sharedlib
		bool "shared lib"
		depends !minidlna-staticlink

	config libflac-staticlib
		bool "static lib"
		depends minidlna-staticlink
endchoice
